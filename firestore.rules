rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to get partnership ID (sorted)
    function getPartnershipId(uid1, uid2) {
      return uid1 < uid2 ? uid1 + '_' + uid2 : uid2 + '_' + uid1;
    }

    // Check if user is a member of the library (owner or partner)
    function isLibraryMember(userId, libraryOwnerId) {
      return userId == libraryOwnerId ||
             exists(path('/databases/' + database + '/documents/partnerships/' + getPartnershipId(userId, libraryOwnerId)));
    }

    // Check if a library is public
    function isLibraryPublic(libraryOwnerId) {
      return get(/databases/$(database)/documents/users/$(libraryOwnerId)).data.get('isPublic', false) == true;
    }

    // Check if user has permission to ADD books to the library
    function canAddBook(userId, libraryOwnerId) {
      return userId == libraryOwnerId || (
        exists(path('/databases/' + database + '/documents/partnerships/' + getPartnershipId(userId, libraryOwnerId))) &&
        get(path('/databases/' + database + '/documents/partnerships/' + getPartnershipId(userId, libraryOwnerId))).data.get('allowAddBooks', false) == true
      );
    }

    // ========== USERS COLLECTION ==========
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
      allow delete: if false;
    }

    // ========== PARTNERSHIPS COLLECTION ==========
    match /partnerships/{partnershipId} {
      allow read: if request.auth != null && 
        (request.auth.uid == resource.data.userId1 || 
         request.auth.uid == resource.data.userId2);
         
      allow create: if request.auth != null && 
        (request.auth.uid == request.resource.data.userId1 ||
         request.auth.uid == request.resource.data.userId2);
         
      allow update: if request.auth != null && 
        (request.auth.uid == resource.data.userId1 || 
         request.auth.uid == resource.data.userId2);
         
      allow delete: if request.auth != null && 
        (request.auth.uid == resource.data.userId1 || 
         request.auth.uid == resource.data.userId2);
    }

    // ========== COLLABORATION REQUESTS COLLECTION ==========
    match /collaborationRequests/{requestId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.fromUserId ||
        request.auth.uid == resource.data.toUserId
      );
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.fromUserId;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.toUserId // Receiver can accept/reject
      );
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.fromUserId ||
        request.auth.uid == resource.data.toUserId
      );
    }

    // ========== BOOKS COLLECTION ==========
    match /books/{bookId} {
      // Allow read if user is the owner, a partner, or if the library is public
      allow read: if request.auth != null && (
        isLibraryMember(request.auth.uid, resource.data.userId) ||
        isLibraryPublic(resource.data.userId)
      );
      
      allow create: if request.auth != null &&
        canAddBook(request.auth.uid, request.resource.data.userId);

      // Only the library owner can delete
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.userId;

      // Only the library owner can update, EXCEPT for returning a book
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        (isLibraryMember(request.auth.uid, resource.data.userId) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['borrowedBy', 'borrowDate']))
      );
    }

    // ========== READING STATUS SUBCOLLECTION ==========
    match /books/{bookId}/readingStatus/{userId} {
      // Allow users to read their own status, or all statuses if they are library members or the library is public
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        isLibraryMember(request.auth.uid, get(/databases/$(database)/documents/books/$(bookId)).data.userId) ||
        isLibraryPublic(get(/databases/$(database)/documents/books/$(bookId)).data.userId)
      );
      
      allow create, update: if request.auth != null && 
        (request.auth.uid == userId || request.resource.data.userId == request.auth.uid);
      
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Support Collection Group queries for readingStatus
    match /{path=**}/readingStatus/{docId} {
      allow read: if request.auth != null && (request.auth.uid == docId || (resource != null && resource.data.userId == request.auth.uid));
    }

    // ========== TRANSFER REQUESTS COLLECTION ==========
    match /transferRequests/{requestId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.fromUserId ||
        request.auth.uid == resource.data.toUserId
      );
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.fromUserId;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.fromUserId ||
        request.auth.uid == resource.data.toUserId
      );
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.fromUserId ||
        request.auth.uid == resource.data.toUserId
      );
    }

    // ========== ACTIVITY FEED COLLECTION ==========
    match /activityFeed/{activityId} {
      allow read: if request.auth != null &&
        isLibraryMember(request.auth.uid, resource.data.libraryId);
      
      allow create: if request.auth != null && (
        request.auth.uid == request.resource.data.userId &&
        isLibraryMember(request.auth.uid, request.resource.data.libraryId)
      );

      allow update, delete: if false;
    }
  }
}
