rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========== USERS COLLECTION ==========
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId;
      allow update, delete: if request.auth.uid == userId;
    }

    // ========== PARTNERSHIPS COLLECTION ==========
    match /partnerships/{partnershipId} {
      allow read: if request.auth != null && 
        (request.auth.uid == resource.data.userId1 || 
         request.auth.uid == resource.data.userId2);
         
      allow create: if request.auth != null && 
        request.auth.uid in [request.resource.data.userId1, request.resource.data.userId2];
         
      allow update: if request.auth != null && 
        (request.auth.uid == resource.data.userId1 || 
         request.auth.uid == resource.data.userId2);
         
      allow delete: if request.auth != null && 
        (request.auth.uid == resource.data.userId1 || 
         request.auth.uid == resource.data.userId2);
    }

    // ========== BOOKS COLLECTION ==========
    match /books/{bookId} {
      allow read: if request.auth != null;
      
      // Helper function to get partnership ID (sorted)
      function getPartnershipId(uid1, uid2) {
        return uid1 < uid2 ? uid1 + '_' + uid2 : uid2 + '_' + uid1;
      }
      
      allow create: if request.auth != null && (
        // User can create books in their own library
        request.auth.uid == request.resource.data.userId ||
        // User can add books to partner's library if permission is granted
        (request.auth.uid != request.resource.data.userId &&
         exists(/databases/$(database)/documents/partnerships/$(
           getPartnershipId(request.auth.uid, request.resource.data.userId)
         )) &&
         get(/databases/$(database)/documents/partnerships/$(
           getPartnershipId(request.auth.uid, request.resource.data.userId)
         )).data.get('allowAddBooks', false) == true)
      );
        
      allow update: if request.auth != null && 
        request.auth.uid == resource.data.userId;
        
      allow delete: if request.auth != null && 
        request.auth.uid == resource.data.userId;

      // ===== READING STATUS SUBCOLLECTION =====
      // Allow any authenticated user to READ (for ratings/comments display)
      // Only owner can WRITE (for their own status)
      match /readingStatus/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth.uid == userId;
      }
    }
  }
}
